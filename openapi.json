{"openapi":"3.1.0","info":{"title":"IR INFOTECH API","description":"\n## AI-Powered REST API\n\nBuilt with **FastAPI** using **Google Gemini** as primary AI and **Groq** as fallback.\n\n### Available Endpoints\n- **POST /summarize** — Summarize long text\n- **POST /translate** — Translate text to any language\n- **POST /generate-email** — Generate professional emails\n    ","version":"1.0.0"},"paths":{"/summarize":{"post":{"tags":["Summarize"],"summary":"Summarize Text","description":"Summarizes the provided text using Gemini (falls back to Groq).","operationId":"summarize_summarize_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SummarizeRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SummarizeResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/translate":{"post":{"tags":["Translate"],"summary":"Translate Text","description":"Translates text to a target language using Gemini (falls back to Groq).","operationId":"translate_translate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/TranslateRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/TranslateResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/generate-email":{"post":{"tags":["Generate Email"],"summary":"Generate Email","description":"Generates a professional email using Gemini (falls back to Groq).","operationId":"generate_email_route_generate_email_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenerateEmailRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenerateEmailResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/":{"get":{"tags":["Health"],"summary":"Root","operationId":"root__get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/health":{"get":{"tags":["Health"],"summary":"Health","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}}},"components":{"schemas":{"GenerateEmailRequest":{"properties":{"purpose":{"type":"string","minLength":10,"title":"Purpose","description":"Purpose of the email"},"recipient_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Recipient Name","description":"Recipient name"},"sender_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Sender Name","description":"Your name"},"tone":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Tone","description":"Tone: professional, formal, friendly","default":"professional"},"additional_context":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Additional Context","description":"Extra context or details"}},"type":"object","required":["purpose"],"title":"GenerateEmailRequest"},"GenerateEmailResponse":{"properties":{"subject":{"type":"string","title":"Subject"},"body":{"type":"string","title":"Body"},"provider":{"type":"string","title":"Provider"}},"type":"object","required":["subject","body","provider"],"title":"GenerateEmailResponse"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"SummarizeRequest":{"properties":{"text":{"type":"string","minLength":50,"title":"Text","description":"Text to summarize (min 50 chars)"},"max_words":{"anyOf":[{"type":"integer","maximum":500.0,"minimum":50.0},{"type":"null"}],"title":"Max Words","description":"Max words in summary","default":150}},"type":"object","required":["text"],"title":"SummarizeRequest"},"SummarizeResponse":{"properties":{"summary":{"type":"string","title":"Summary"},"word_count":{"type":"integer","title":"Word Count"},"provider":{"type":"string","title":"Provider"}},"type":"object","required":["summary","word_count","provider"],"title":"SummarizeResponse"},"TranslateRequest":{"properties":{"text":{"type":"string","minLength":1,"title":"Text","description":"Text to translate"},"target_language":{"type":"string","title":"Target Language","description":"Target language e.g. 'French', 'Hindi'"},"source_language":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Source Language","description":"Source language (default: auto-detect)","default":"auto"}},"type":"object","required":["text","target_language"],"title":"TranslateRequest"},"TranslateResponse":{"properties":{"translated_text":{"type":"string","title":"Translated Text"},"source_language":{"type":"string","title":"Source Language"},"target_language":{"type":"string","title":"Target Language"},"provider":{"type":"string","title":"Provider"}},"type":"object","required":["translated_text","source_language","target_language","provider"],"title":"TranslateResponse"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"},"input":{"title":"Input"},"ctx":{"type":"object","title":"Context"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}